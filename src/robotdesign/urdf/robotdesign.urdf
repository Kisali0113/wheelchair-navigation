<?xml version="1.0" encoding="utf-8"?>
<robot name="robotdesign">
  
  <link name="base_link">
    <inertial>
      <origin xyz="0.18001 2.8315E-06 0.14277" rpy="0 0 0" />
      <mass value="6.1354" />
      <inertia ixx="0.09231" ixy="0.0077966" ixz="-0.0068618" iyy="0.095327" iyz="-5.98E-05" izz="0.056644" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/base_link.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="rightwheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="3.4212" />
      <inertia ixx="0.012658" ixy="0" ixz="0" iyy="0.012658" iyz="0" izz="0.020698" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/rightwheel.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/rightwheel.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="rightwheeljoint" type="continuous">
    <origin xyz="-0.3763 -0.42416 0.01" rpy="1.5708 0 0" />
    <parent link="base_link" />
    <child link="rightwheel" />
    <axis xyz="0 0 -1" />
    <dynamics damping="0.1" friction="0" />
  </joint>

  <link name="leftwheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="3.4212" />
      <inertia ixx="0.012658" ixy="0" ixz="0" iyy="0.012658" iyz="0" izz="0.020698" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/leftwheel.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/leftwheel.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="leftwheeljoint" type="continuous">
    <origin xyz="-0.3763 0.42197 0.01" rpy="1.5708 0 0" />
    <parent link="base_link" />
    <child link="leftwheel" />
    <axis xyz="0 0 1" />
    <dynamics damping="0.1" friction="0" />
  </joint>

  <link name="front">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.26848" />
      <inertia ixx="0.0013401" ixy="0" ixz="0" iyy="0.00092232" iyz="0" izz="0.00079466" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/front.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/front.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="frontjoint" type="revolute">
    <origin xyz="0.67273 0 0.2939" rpy="3.1416 0 0" />
    <parent link="base_link" />
    <child link="front" />
    <axis xyz="0 0 -1" />
    <limit lower="-1.0472" upper="1.0472" effort="5" velocity="2" />
    <dynamics damping="0.1" friction="0" />
  </joint>

  <link name="frontwheel">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="4.0537" />
      <inertia ixx="0.018746" ixy="0" ixz="0" iyy="0.018507" iyz="0" izz="0.032452" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/frontwheel.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/frontwheel.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="frontwheeljoint" type="continuous">
    <origin xyz="-0.0080085 -0.061174 0.26898" rpy="-1.5708 0 0" />
    <parent link="front" />
    <child link="frontwheel" />
    <axis xyz="-0.12981 0 -0.99154" />
    <dynamics damping="0.1" friction="0" />
  </joint>

  <link name="chairleft">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.68594" />
      <inertia ixx="0.0021357" ixy="0" ixz="0" iyy="0.0039087" iyz="0" izz="0.0022193" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/chairleft.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/chairleft.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="chairleftjoint" type="revolute">
    <origin xyz="0.089732 0.25 0.77" rpy="3.1416 0 0" />
    <parent link="base_link" />
    <child link="chairleft" />
    <axis xyz="0 0 -1" />
    <limit lower="-1.04" upper="0" effort="5" velocity="2" />
    <dynamics damping="0.1" friction="0" />
  </joint>

  <link name="chairright">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.68594" />
      <inertia ixx="0.0021357" ixy="0" ixz="0" iyy="0.0039087" iyz="0" izz="0.0022193" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/chairright.STL" />
      </geometry>
      <material name="">
        <color rgba="0.79216 0.81961 0.93333 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file:///home/kisali/fyp_ws/src/robotdesign/meshes/chairright.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="chairrightjoint" type="revolute">
    <origin xyz="0.089732 -0.25 0.77" rpy="3.1416 0 0" />
    <parent link="base_link" />
    <child link="chairright" />
    <axis xyz="0 0 -1" />
    <limit lower="0" upper="1.04" effort="5" velocity="2" />
    <dynamics damping="0.1" friction="0" />
  </joint>

  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.2 0 0.8" rpy="0 0 0"/>
  </joint>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
      </camera>
      <plugin name="gz::sim::systems::Sensors" filename="libgz-sim-sensors-system.so"/>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="wheelchair_imu" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <topic>/imu/data</topic>
      <gz_frame_id>base_link</gz_frame_id>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.001</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.01</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin
      filename="libgz-sim-ackermann-steering-system.so"
      name="gz::sim::systems::AckermannSteering">
      <left_joint>leftwheeljoint</left_joint>
      <right_joint>rightwheeljoint</right_joint>
      
      <left_steering_joint>frontjoint</left_steering_joint>
      <right_steering_joint>frontjoint</right_steering_joint>
      
      <wheel_base>1.049</wheel_base>
      <wheel_separation>0.846</wheel_separation>
      <wheel_radius>0.15</wheel_radius> 
      <steering_limit>1.047</steering_limit>
      
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/wheel/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo reference="base_link">
    <sensor name="wheelchair_lidar" type="gpu_lidar">
      <pose>1.08 0.08 0.23 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>10.0</update_rate>
      <visualize>true</visualize>
      <topic>/scan</topic>
      <gz_frame_id>laser</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>


</robot>
